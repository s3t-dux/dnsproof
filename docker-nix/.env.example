APP_MASTER_KEY=changeme
DNSPROOF_PASSWORD=changeme

# Database
# Default: local SQLite. No PostgreSQL setup required.
DB_PATH=./dnsproof.db

# Optional: override DB_PATH with a full SQLAlchemy database URL.
# SQLite example:
# DATABASE_URL=sqlite:///./dnsproof.db
#
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://dnsproof_user:password@127.0.0.1:5432/dnsproof
#
# Note: for PostgreSQL, create the database first. DNSProof creates tables on startup,
# but it does not create the PostgreSQL database itself.
